{
    "name": "vendor/laravel-notification-center",
    "description": "A headless notification center for Laravel.",
    "keywords": [
        "laravel",
        "notifications",
        "notification-center",
        "headless"
    ],
    "homepage": "https://github.com/vendor/laravel-notification-center",
    "license": "MIT",
    "authors": [
        {
            "name": "Vendor Name",
            "email": "author@example.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/vendor/laravel-notification-center/issues",
        "source": "https://github.com/vendor/laravel-notification-center"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\NotificationCenter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\NotificationCenter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "pint": "pint",
        "phpstan": "phpstan analyse",
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\NotificationCenter\\NotificationCenterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
